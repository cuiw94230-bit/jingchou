:root {
  --bg: #f5f7fb;
  --panel: #ffffff;
  --text: #0f172a;
  --sub: #475569;
  --line: #dbe2ea;
  --blue: #2563eb;
  --blue-dark: #1d4ed8;
  --risk: #dc2626;
  --warn: #d97706;
  --ok: #059669;
}
* { box-sizing: border-box; }
body { margin: 0; background: var(--bg); color: var(--text); font-family: "Microsoft YaHei", "PingFang SC", sans-serif; }
.dt-shell { max-width: 1400px; margin: 0 auto; padding: 24px; }
.dt-hero { display: flex; justify-content: space-between; gap: 16px; align-items: flex-start; margin-bottom: 16px; }
.dt-eyebrow { margin: 0 0 8px; font-size: 13px; letter-spacing: 2px; color: #64748b; }
.dt-hero h1 { margin: 0; font-size: 42px; line-height: 1.15; }
.dt-hero-actions { display: flex; gap: 10px; flex-wrap: wrap; }
.dt-btn { height: 40px; padding: 0 16px; border-radius: 20px; border: 1px solid #cbd5e1; background: #fff; color: #1e293b; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; }
.dt-btn:hover { border-color: #94a3b8; }
.dt-btn.dt-primary { border-color: var(--blue); background: var(--blue); color: #fff; }
.dt-btn.dt-primary:hover { background: var(--blue-dark); }
.dt-panel { background: var(--panel); border: 1px solid var(--line); border-radius: 14px; padding: 14px 16px; margin-bottom: 12px; }
.dt-toolbar { display: flex; align-items: end; gap: 12px; flex-wrap: wrap; }
.dt-field { display: grid; gap: 6px; }
.dt-field span { font-size: 13px; color: var(--sub); }
.dt-field input { height: 38px; border: 1px solid #cbd5e1; border-radius: 10px; padding: 0 10px; min-width: 180px; }
.dt-status { font-size: 13px; color: var(--sub); min-height: 20px; }
.dt-kpi-grid { display: grid; grid-template-columns: repeat(5, minmax(120px, 1fr)); gap: 10px; }
.dt-kpi { border: 1px solid var(--line); border-radius: 10px; padding: 10px; background: #f8fafc; }
.dt-kpi .k { color: var(--sub); font-size: 12px; margin-bottom: 4px; }
.dt-kpi .v { font-size: 24px; font-weight: 700; }
.dt-filter-row { display: flex; gap: 8px; flex-wrap: wrap; }
.dt-filter-btn { border: 1px solid #cbd5e1; background: #fff; color: #334155; border-radius: 16px; height: 34px; padding: 0 12px; cursor: pointer; }
.dt-filter-btn.active { border-color: var(--blue); color: var(--blue); background: #eff6ff; }
.dt-cards { display: grid; gap: 10px; max-height: 58vh; overflow: auto; padding-right: 4px; }
.dt-card { border: 1px solid var(--line); border-radius: 12px; padding: 12px; background: #fff; }
.dt-card-top { display: grid; grid-template-columns: repeat(5, minmax(120px, auto)); gap: 8px; margin-bottom: 8px; }
.dt-tag { display: inline-flex; align-items: center; padding: 2px 10px; border-radius: 999px; font-size: 12px; border: 1px solid #cbd5e1; background: #f8fafc; }
.dt-tag.risk { border-color: #fecaca; color: #b91c1c; background: #fef2f2; }
.dt-tag.review { border-color: #fde68a; color: #92400e; background: #fffbeb; }
.dt-tag.stable { border-color: #bbf7d0; color: #065f46; background: #ecfdf5; }
.dt-explain { margin: 0; white-space: pre-wrap; line-height: 1.6; color: #1f2937; font-size: 14px; }
@media (max-width: 960px) {
  .dt-kpi-grid { grid-template-columns: repeat(2, minmax(120px, 1fr)); }
  .dt-card-top { grid-template-columns: repeat(2, minmax(120px, 1fr)); }
}
