      <article class="rg-kpi-card">
        <div class="rg-kpi-label">${c.label}</div>
        <div class="rg-kpi-value">${c.value}</div>
        <div class="rg-kpi-sub">${c.sub}</div>
      </article>
    `).join("");
  }

  function renderWaveBreakdown(items) {
    if (!items || !items.length) {
